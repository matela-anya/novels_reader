{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "outputDirectory": "webapp",
  "routes": [
    { 
      "src": "/js/(.*)",
      "dest": "/webapp/js/$1"
    },
    { 
      "src": "/css/(.*)",
      "dest": "/webapp/css/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/webapp/$1"
    }
  ]
}
